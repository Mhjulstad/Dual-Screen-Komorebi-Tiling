{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.37/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 1,
  "default_container_padding": -2,
  "border": true,
"border_width": 4,
"border_offset": -1,
"border_style": "Rounded",
"mouse_follows_focus": true,
"border_colours": {
  "single": "#61AFEF",
  "stack": "#98C379",
  "monocle": "#C678DD", 
  "unfocused": "#3E4451" 
},
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP",
          "workspace_rules": [
            {
              "id": "Soulstone Survivors.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "II",
          "layout": "BSP"
        },
        {
          "name": "III",
          "layout": "BSP",
